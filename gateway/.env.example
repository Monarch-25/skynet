# ---- Gateway configuration ----
# Copy this file to ../.env (project root) and fill in real values.
# The .env file is gitignored and loaded automatically by the gateway.

# REQUIRED: your Z.AI API key (https://z.ai/manage-apikey/apikey-list)
ZAI_API_KEY=your-zai-api-key-here

# Optional overrides (defaults shown)
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
# GATEWAY_PROVIDER=zai          # "zai" now, "bedrock" later
# GATEWAY_MODEL=glm-5.2
# GATEWAY_TEMPERATURE=0.6
# GATEWAY_MAX_TOKENS=
# GATEWAY_TIMEOUT=60.0
# GATEWAY_MAX_RETRIES=3
# GATEWAY_THINKING=false
